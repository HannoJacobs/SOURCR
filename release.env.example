SOURCR_CODESIGN_MODE="adhoc"

# Set to:
# - accepted: signed and notarized builds that Gatekeeper should accept
# - rejected: signed but intentionally unnotarized builds that Gatekeeper should reject
# - skip: do not enforce spctl outcome
#
# Default for this repo:
# - adhoc mode: rejected
SOURCR_SPCTL_EXPECT="rejected"

# Optional advanced override only if you deliberately switch to developer_id mode:
# SOURCR_CODESIGN_IDENTITY="Developer ID Application: Your Name (TEAMID)"
